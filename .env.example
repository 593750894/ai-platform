# =============================================================
# SeedLandV — 环境变量样板
# 复制为 .env 并填值；.env 不进 git
# =============================================================

# --- Electron 客户端 ----------------------------------------
# 后端 API 地址；dev 默认 http://localhost:8000
SEEDLANDV_API_URL=http://localhost:8000

# Phase 0-2 过渡期：直连 Ark 仍需，Phase 3 切到后端后可删
VOLC_ARK_API_KEY=

# --- 后端 server/ -------------------------------------------
# Postgres
DATABASE_URL=postgresql+psycopg://seedlandv:seedlandv_dev@localhost:5432/seedlandv

# Redis（Celery broker + 缓存 + pub/sub）
REDIS_URL=redis://localhost:6379/0

# JWT 签名密钥（生产环境用 openssl rand -hex 32 重新生成）
JWT_SECRET=dev_only_change_me_in_production_xxxxxxxxxxxxxxxx
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=604800

# 租户 Ark Key 加密（Fernet 对称密钥；用 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 生成）
ARK_KEY_FERNET_SECRET=

# --- 火山 TOS（对象存储）------------------------------------
# 控制台: https://console.volcengine.com/tos
# 子账号 AK/SK 仅授予目标 bucket 的读写权限
VOLC_TOS_AK=
VOLC_TOS_SK=
VOLC_TOS_REGION=cn-beijing
VOLC_TOS_ENDPOINT=tos-cn-beijing.volces.com
VOLC_TOS_BUCKET=seedlandv-dev

# --- Ark API（默认值，一般不动）-----------------------------
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
