// SeedLand · V — AI 视频社群平台数据模型
// 详细文档：https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ───────────────────────────── enums ─────────────────────────────

enum Role {
  USER
  MOD
  ADMIN
}

enum WorkModel {
  SEEDANCE_2_0
  SEEDANCE_FAST
}

enum WorkMode {
  TEXT_TO_VIDEO
  IMAGE_TO_VIDEO
  FIRST_LAST_FRAME
  MULTI_REFERENCE
}

enum CollaborationType {
  LOOKING_FOR // 我正在找
  OFFERING    // 我可以提供
}

enum CollaborationStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum ToolPricing {
  FREE
  FREEMIUM
  PAID
}

// ───────────────────────────── User ─────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  name         String
  avatar       String?
  bio          String?
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)

  // 阶段 3 个人主页字段
  industryRole   String?  @map("industry_role") // 行业角色，例如 "导演 / 编剧"
  expertise      String[] @default([]) // 擅长领域
  favoriteTools  String[] @default([]) @map("favorite_tools") // 常用 AI 视频工具
  portfolioLinks String[] @default([]) @map("portfolio_links") // 作品链接
  contact        String?  // 联系方式，可选

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // owner of channels they created
  ownedChannels      Channel[]                 @relation("ChannelOwner")
  // many-to-many membership
  channelMemberships ChannelMember[]
  posts              Post[]
  comments           Comment[]
  works              Work[]
  collaborations     Collaboration[]
  toolsContributed   Tool[]                    @relation("ToolContributor")
  conversations      ConversationParticipant[]
  messagesSent       Message[]                 @relation("MessageSender")
  likes              Like[]
  bookmarks          Bookmark[]

  @@map("users")
}

// ───────────────────────────── Channel ─────────────────────────────

model Channel {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  banner      String?
  color       String   @default("#3b82f6")
  ownerId     String   @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")

  owner   User            @relation("ChannelOwner", fields: [ownerId], references: [id])
  members ChannelMember[]
  posts   Post[]

  @@map("channels")
}

model ChannelMember {
  channelId String   @map("channel_id")
  userId    String   @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
  @@map("channel_members")
}

// ───────────────────────────── Post ─────────────────────────────

model Post {
  id           String   @id @default(cuid())
  channelId    String   @map("channel_id")
  authorId     String   @map("author_id")
  title        String
  content      String
  views        Int      @default(0)
  likeCount    Int      @default(0) @map("like_count")
  commentCount Int      @default(0) @map("comment_count")
  pinned       Boolean  @default(false)
  locked       Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]
  likes     Like[]
  bookmarks Bookmark[]

  @@index([channelId, createdAt])
  @@index([authorId])
  @@map("posts")
}

// ───────────────────────────── Comment ─────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  authorId  String   @map("author_id")
  parentId  String?  @map("parent_id")
  content   String
  likeCount Int      @default(0) @map("like_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentReplies")
  likes   Like[]

  @@index([postId, createdAt])
  @@map("comments")
}

// ───────────────────────────── Work (用户 AI 视频作品) ─────────────────────────────

model Work {
  id            String    @id @default(cuid())
  authorId      String    @map("author_id")
  title         String
  description   String?
  videoUrl      String    @map("video_url")
  thumbnailUrl  String?   @map("thumbnail_url")
  model         WorkModel @default(SEEDANCE_2_0)
  mode          WorkMode  @default(TEXT_TO_VIDEO)
  prompt        String?
  durationSec   Int?      @map("duration_sec")
  resolution    String? // 例 "1080p"
  ratio         String? // 例 "16:9"
  views         Int       @default(0)
  likeCount     Int       @default(0) @map("like_count")
  bookmarkCount Int       @default(0) @map("bookmark_count")
  isPublic      Boolean   @default(true) @map("is_public")
  createdAt     DateTime  @default(now()) @map("created_at")

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     Like[]
  bookmarks Bookmark[]

  @@index([authorId])
  @@index([createdAt])
  @@map("works")
}

// ───────────────────────────── Collaboration (合作需求) ─────────────────────────────

model Collaboration {
  id          String              @id @default(cuid())
  authorId    String              @map("author_id")
  title       String
  description String
  type        CollaborationType
  status      CollaborationStatus @default(OPEN)
  budget      String?
  deadline    DateTime?
  tags        String[]
  createdAt   DateTime            @default(now()) @map("created_at")

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([type])
  @@map("collaborations")
}

// ───────────────────────────── Tool (工具库) ─────────────────────────────

model Tool {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  url         String
  category    String
  logoUrl     String?     @map("logo_url")
  pricing     ToolPricing @default(FREE)
  tags        String[]
  isOfficial  Boolean     @default(false) @map("is_official")
  createdById String?     @map("created_by_id")
  createdAt   DateTime    @default(now()) @map("created_at")

  createdBy User? @relation("ToolContributor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([category])
  @@map("tools")
}

// ───────────────────────────── Conversation + Message ─────────────────────────────

model Conversation {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now()) @map("created_at")
  lastMessageAt DateTime @default(now()) @map("last_message_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationParticipant {
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  joinedAt       DateTime @default(now()) @map("joined_at")
  lastReadAt     DateTime @default(now()) @map("last_read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  senderId       String    @map("sender_id")
  content        String
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ───────────────────────────── Like (polymorphic: post | work | comment) ─────────────────────────────

model Like {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  postId    String?  @map("post_id")
  workId    String?  @map("work_id")
  commentId String?  @map("comment_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  work    Work?    @relation(fields: [workId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  // 一个用户对同一目标只能点一次赞
  @@unique([userId, postId])
  @@unique([userId, workId])
  @@unique([userId, commentId])
  @@map("likes")
}

// ───────────────────────────── Bookmark (post | work) ─────────────────────────────

model Bookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  postId    String?  @map("post_id")
  workId    String?  @map("work_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: Cascade)
  work Work? @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, workId])
  @@map("bookmarks")
}
