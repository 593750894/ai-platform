# SeedLand · V (web) — environment variables
# Copy to .env and fill in the values before running `npm run dev`.

# ─── Database ─────────────────────────────────────────────────────────────
# Postgres connection string used by Prisma + the pg adapter.
#
# Option A — Prisma Dev (recommended for local dev, zero-install postgres):
#   $ npx prisma dev start seedlandv      # prints the actual TCP port
#   Then paste the printed `postgres://...` URL here.
#   Example (port will vary):
DATABASE_URL="postgres://postgres:postgres@localhost:51218/template1?sslmode=disable"

# Option B — Docker compose at repo root (postgres:16 on :5432):
#   $ docker compose -f docker-compose.dev.yml up -d postgres
# DATABASE_URL="postgresql://seedlandv:seedlandv_dev@localhost:5432/seedlandv?schema=public"

# Option C — Any managed Postgres (Neon, Supabase, RDS, …):
# DATABASE_URL="postgresql://USER:PASS@HOST:5432/DBNAME?schema=public&sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────
# HS256 signing secret for the seedland_session JWT cookie (jose).
# Generate a fresh one with:
#   $ node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-me-with-a-base64-32-byte-secret"

# ─── App ──────────────────────────────────────────────────────────────
# NODE_ENV is set automatically by Next.js (development / production).
# Only override if you know what you're doing.
# NODE_ENV="development"
